import React, { useState, useEffect, useRef } from "react";
import { base44 } from "@/api/base44Client";
import { Send, Loader2 } from "lucide-react";
import moment from "moment";

export default function ChatWidget({ conversationId, clientName, clientEmail }) {
  const [messages, setMessages] = useState([]);
  const [input, setInput] = useState("");
  const [loading, setLoading] = useState(true);
  const [sending, setSending] = useState(false);
  const bottomRef = useRef(null);

  useEffect(() => {
    if (!conversationId) return;
    loadMessages();
    const unsub = base44.entities.ChatMessage.subscribe((event) => {
      if (event.data?.conversation_id === conversationId) {
        if (event.type === "create") {
          setMessages((prev) => [...prev, event.data]);
        }
      }
    });
    return unsub;
  }, [conversationId]);

  useEffect(() => {
    bottomRef.current?.scrollIntoView({ behavior: "smooth" });
  }, [messages]);

  async function loadMessages() {
    setLoading(true);
    const msgs = await base44.entities.ChatMessage.filter(
      { conversation_id: conversationId },
      "created_date",
      200
    );
    setMessages(msgs);
    setLoading(false);
  }

  async function sendMessage(e) {
    e.preventDefault();
    if (!input.trim() || sending) return;
    setSending(true);
    const msg = input.trim();
    setInput("");
    await base44.entities.ChatMessage.create({
      conversation_id: conversationId,
      sender_type: "client",
      sender_name: clientName,
      message: msg,
    });
    await base44.entities.ChatConversation.update(conversationId, {
      last_message: msg,
      last_message_date: new Date().toISOString(),
      unread_count: 1,
    });
    setSending(false);
  }

  return (
    <div className="flex flex-col h-full">
      {/* Messages area */}
      <div className="flex-1 overflow-y-auto p-4 lg:p-6 space-y-4">
        {loading ? (
          <div className="flex items-center justify-center h-full">
            <Loader2 size={24} className="animate-spin text-[#8C8C85]" />
          </div>
        ) : messages.length === 0 ? (
          <div className="flex flex-col items-center justify-center h-full text-center py-12">
            <div className="w-16 h-16 rounded-full bg-[#0055FF]/10 flex items-center justify-center mb-4">
              <Send size={24} className="text-[#0055FF]" />
            </div>
            <p className="font-heading text-lg font-semibold text-[#1A1A1A] mb-2">
              Start the Conversation
            </p>
            <p className="text-sm text-[#8C8C85] max-w-xs">
 
